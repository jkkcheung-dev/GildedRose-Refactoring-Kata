{
  "compilerOptions": {
    "module": "nodenext",
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "moduleResolution": "nodenext",
    "strict": true,
    "noImplicitAny": false,
    "rootDir": ".",
    "outDir": "./dist",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "resolvePackageJsonImports": true,
    "resolvePackageJsonExports": true
  },
  "include": [
    "app/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "coverage",
    "dist",
    "node_modules"
  ]
}
