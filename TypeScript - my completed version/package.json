{
  "name": "gilded-rose-kata",
  "version": "1.0.0",
  "description": "Gilded Rose kata in TypeScript",
  "scripts": {
    "clean": "rimraf --glob \"app/**/*.js\" \"app/**/*.js.map\" \"test/**/*.js\" \"test/**/*.js.map\" vitest.config.js vitest.config.js.map vitest.config.mjs vitest.config.mjs.map coverage",
    "prebuild": "npm run clean",
    "build": "tsc",
    "compile": "npm run build",
    "pretest": "npm run clean",
    "test": "vitest run --coverage",
    "test:vitest": "npm run test",
    "test:watch": "vitest",
    "texttest": "ts-node test/golden-master-text-test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "imports": {
    "#app/*": "./app/*.ts"
  },
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}